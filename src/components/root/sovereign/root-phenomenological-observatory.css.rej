+.po-resolve{
+  position:absolute;bottom:18px;left:290px;z-index:21;
+  border:1px solid rgba(200,169,81,.4);background:#0b0b09;
+  padding:10px 12px;display:grid;gap:8px;width:280px;max-width:calc(100vw - 320px);
+}
+.po-resolve>span{font-size:8px;letter-spacing:.16em;color:#c8a951;text-transform:uppercase;}
+.po-resolve-list{display:grid;gap:4px;max-height:220px;overflow-y:auto;}
+.po-resolve-item{
+  display:grid;gap:2px;text-align:left;border:1px solid #1a170f;background:#050504;
+  color:#eee4cb;padding:6px 8px;cursor:pointer;font-family:inherit;
+}
+.po-resolve-item:hover{border-color:#c9aa54;}
+.po-resolve-item:disabled{opacity:.4;cursor:not-allowed;}
+.po-resolve-item strong{font-size:10px;font-weight:400;color:#f5eedc;}
+.po-resolve-item span{font-size:8px;letter-spacing:.08em;color:#8f8878;}
+.po-resolve-actions{display:flex;gap:6px;}
+.po-resolve-actions button{
+  flex:1;border:1px solid #c8a95166;background:transparent;color:#c8a951;
+  font-size:8px;letter-spacing:.08em;padding:6px;cursor:pointer;text-transform:uppercase;
+}
+@media(max-width:640px){.po-resolve{left:14px;bottom:110px;width:calc(100vw - 28px);max-width:none;}}
