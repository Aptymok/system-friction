-.rs-metric {
-
-  padding:16px;
-
-  border:
-
-  1px solid rgba(255,255,255,.1);
-
+.pc-header{border-left:2px solid #c8a951;padding-left:14px;margin-bottom:18px;}
+.pc-header span{display:block;color:#c8a951;font-size:9px;letter-spacing:.18em;text-transform:uppercase;}
+.pc-header h1{font-family:'Cormorant Garamond',serif;font-weight:600;font-size:26px;color:#f5eedc;margin:6px 0 4px;}
+.pc-header p{color:#8f8878;font-size:11px;margin:0;}
+
+.pc-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;}
+.pc-wide{grid-column:1/-1;}
+@media(max-width:860px){.pc-grid{grid-template-columns:1fr;}}
+
+.pc-card{border:1px solid #263035;background:#090d0f;padding:14px;min-width:0;}
+.pc-card h2{font-size:10px;letter-spacing:.14em;color:#c8a951;text-transform:uppercase;margin:0 0 10px;}
+
+.pc-dl{display:grid;gap:1px;margin:0;}
+.pc-dl div{display:grid;grid-template-columns:120px 1fr;border-bottom:1px solid #1a2024;padding:7px 0;font-size:10px;}
+.pc-dl dt{color:#78858a;}
+.pc-dl dd{margin:0;color:#d6dcda;}
+
+.pc-composite{font-size:12px;color:#9fb1b6;line-height:1.5;border-left:1px solid #263035;padding-left:10px;margin:0 0 12px;}
+
+.pc-indices{display:grid;gap:12px;}
+.pc-index-row{display:grid;gap:4px;}
+.pc-index-head{display:flex;justify-content:space-between;font-size:9px;letter-spacing:.06em;color:#d6dcda;}
+.pc-index-head span{color:#54c7d2;}
+.pc-index-bar{height:4px;background:#161b1d;border:1px solid #263035;}
+.pc-index-bar i{display:block;height:100%;background:#c8a951;}
+.pc-index-row p{margin:0;font-size:9px;line-height:1.5;color:#78858a;}
+
+.pc-hypothesis{display:grid;gap:8px;}
+.pc-direction{font-size:11px;color:#e5c18e;margin:0;}
+.pc-rationale{font-size:10px;line-height:1.55;color:#9fb1b6;margin:0;border-left:1px solid #263035;padding-left:10px;}
+.pc-rival{border-top:1px solid #1a2024;padding-top:8px;display:grid;gap:4px;}
+.pc-rival>span{font-size:8px;letter-spacing:.12em;color:#667075;}
+.pc-rival p{margin:0;font-size:9px;line-height:1.5;color:#78858a;}
+
+.pc-suggestion{font-size:11px;line-height:1.6;color:#d6dcda;margin:0 0 12px;border-left:2px solid #c8a951;padding-left:10px;}
+.pc-recalibrate{border:1px solid #c8a95166;background:transparent;color:#c8a951;font-size:9px;letter-spacing:.1em;padding:8px 12px;cursor:pointer;text-transform:uppercase;}
+.pc-recalibrate:disabled{opacity:.45;cursor:not-allowed;}
+.pc-error{display:block;margin-top:8px;color:#e06c67;font-size:9px;}
+
+.pc-timeline{list-style:none;margin:0;padding:0;display:grid;gap:1px;max-height:420px;overflow-y:auto;}
+.pc-timeline li{display:grid;grid-template-columns:170px 1fr;gap:12px;padding:9px 0;border-bottom:1px solid #1a2024;}
+.pc-timeline time{color:#78858a;font-size:9px;}
+.pc-timeline strong{display:block;font-size:10px;color:#d6dcda;margin-bottom:3px;}
+.pc-timeline p{margin:0;font-size:9px;color:#78858a;line-height:1.5;}
+
+.pc-empty{color:#5d574a;font-size:10px;line-height:1.6;margin:0;}
+
+.pc-observers{display:grid;gap:14px;}
+.pc-observer{border-left:2px solid #263035;padding-left:12px;}
+.pc-observer-head{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px;}
+.pc-observer-head strong{font-size:10px;color:#d6dcda;letter-spacing:.04em;}
+.pc-tag-ok{font-size:8px;letter-spacing:.08em;color:#7fd6a8;text-transform:uppercase;}
+.pc-tag-empty{font-size:8px;letter-spacing:.08em;color:#5d574a;text-transform:uppercase;}
+.pc-observer-list{list-style:none;margin:0;padding:0;display:grid;gap:8px;}
+.pc-observer-list li{border-bottom:1px solid #1a2024;padding-bottom:8px;}
+.pc-observer-list strong{display:block;font-size:9px;color:#e5c18e;margin-bottom:3px;}
+.pc-observer-list p{margin:0 0 3px;font-size:9px;color:#9fb1b6;line-height:1.5;}
+.pc-observer-list span{font-size:8px;color:#54c7d2;letter-spacing:.06em;text-transform:uppercase;}
+
+@media(max-width:640px){
+  .pc-timeline li{grid-template-columns:1fr;gap:4px;}
 }
