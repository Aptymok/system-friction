{
  "name": "system-friction-terminal",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "audit:routes": "node scripts/audit-routes.mjs",
    "check:boundaries": "node scripts/check-domain-boundaries.mjs",
    "typecheck": "tsc --noEmit --pretty false --incremental false",
    "phase:verify": "npm run check:boundaries && npm run typecheck"
  },
  "dependencies": {
    "@headlessui/react": "^2.0.0",
    "@supabase/auth-helpers-nextjs": "^0.15.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.105.4",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.468.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "stripe": "^22.1.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "supabase": "^2.98.2",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}
