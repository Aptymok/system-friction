{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/node/[id]",
      "regex": "^/api/node/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/node/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/link/[token]",
      "regex": "^/link/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtoken": "nxtPtoken"
      },
      "namedRegex": "^/link/(?<nxtPtoken>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/api/audit",
      "regex": "^/api/audit(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/audit(?:/)?$"
    },
    {
      "page": "/api/link/generate",
      "regex": "^/api/link/generate(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/link/generate(?:/)?$"
    },
    {
      "page": "/api/link/verify",
      "regex": "^/api/link/verify(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/link/verify(?:/)?$"
    },
    {
      "page": "/api/node/bootstrap",
      "regex": "^/api/node/bootstrap(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/node/bootstrap(?:/)?$"
    },
    {
      "page": "/api/whatsapp/webhook",
      "regex": "^/api/whatsapp/webhook(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/whatsapp/webhook(?:/)?$"
    },
    {
      "page": "/llms.txt",
      "regex": "^/llms\\.txt(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/llms\\.txt(?:/)?$"
    },
    {
      "page": "/robots.txt",
      "regex": "^/robots\\.txt(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/robots\\.txt(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sitemap\\.xml(?:/)?$"
    },
    {
      "page": "/terminal",
      "regex": "^/terminal(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/terminal(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}